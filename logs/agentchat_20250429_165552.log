tring client);\n        Task<List<RecomendationByCategory>> GetRecomendationByCategory(string client);\n        Task<int> GetNumberOfSubscriptions(string client);\n        Task<int> GetNumberOfResources(string client);\n        Task<int> GetNumComplDisaster(string client);\n        Task<int> GetNumNonComplDisaster(string client);\n        Task<int> GetNumComplGovernance(string client);\n        Task<int> GetNumNonComplGovernance(string client);\n        Task<int> GetNumComplHighAvailability(string client);\n        Task<int> GetNumNonComplHighAvailability(string client);\n        Task<int> GetNumComplMonitoringAlerting(string client);\n        Task<int> GetNumNonComplMonitoringAlerting(string client);\n        Task<int> GetNumComplScalability(string client);\n        Task<int> GetNumNonComplScalability(string client);\n        Task<int> GetNumComplSecurity(string client);\n        Task<int> GetNumNonComplSecurity(string client);\n        Task<int> GetLowImpactDisaster(string client);\n        Task<int> GetMediumImpactDisaster(string client);\n        Task<int> GetHighImpactDisaster(string client);\n        Task<int> GetLowImpactGovernance(string client);\n        Task<int> GetMediumImpactGovernance(string client);\n        Task<int> GetHighImpactGovernance(string client);\n        Task<int> GetLowImpactHighAvailability(string client);\n        Task<int> GetMediumImpactHighAvailability(string client);\n        Task<int> GetHighImpactHighAvailability(string client);\n        Task<int> GetLowImpactMonitoringAlerting(string client);\n        Task<int> GetMediumImpactMonitoringAlerting(string client);\n        Task<int> GetHighImpactMonitoringAlerting(string client);\n        Task<int> GetLowImpactScalability(string client);\n        Task<int> GetMediumImpactScalability(string client);\n        Task<int> GetHighImpactScalability(string client);\n        Task<int> GetLowImpactSecurity(string client);\n        Task<int> GetMediumImpactSecurity(string client);\n        Task<int> GetHighImpactSecurity(string client);\n        Task<List<ResourceType>> GetResourceTypes(string client);\n        Task<List<ResourceByRegion>> GetResourcesByRegion(string client);\n        Task<List<ResourceByCategory>> GetResourcesByCategory(string client);\n\n    }\n}\n\n```', name='read_file', call_id='call_1MfGGdz6PZ6iyB6739AMTVrD', is_error=False), FunctionExecutionResult(content='Contenido de ProdwareAzureCopilot.API/Repositories/General/DashboardRepository.cs:\n\n```.cs\n\ufeffusing Microsoft.EntityFrameworkCore;\nusing ProdwareAzureCopilot.API.Domain.Dashboard;\nusing System.Diagnostics;\n\nnamespace ProdwareAzureCopilot.API.Repositories.General\n{\n    public class DashboardRepository : IDashboardRepository\n    {\n        private readonly CosmosClient _cosmosClient;\n        private readonly ILogger<DashboardRepository> _logger;\n        private readonly ApplicationDbContext _context;\n        private string databaseId = "Clients";\n\n        public DashboardRepository(CosmosClient cosmosClient, ILogger<DashboardRepository> logger, ApplicationDbContext context)\n        {\n            _cosmosClient = cosmosClient;\n            _logger = logger;\n            _context = context;\n        }\n\n        private async Task<int> ExecuteCountQueryNormal(Container container, string sqlQueryText)\n        {\n            var queryDefinition = new QueryDefinition(sqlQueryText);\n            var queryResultSetIterator = container.GetItemQueryIterator<int>(queryDefinition);\n\n            int count = 0;\n            while (queryResultSetIterator.HasMoreResults)\n            {\n                var response = await queryResultSetIterator.ReadNextAsync();\n                count += response.Resource.FirstOrDefault();\n            }\n\n            return count;\n        }\n\n        public async Task<float> GetTotalCost(string client)\n        {\n            var container = _cosmosClient.GetContainer(databaseId, client);\n            var sqlQueryText = "SELECT VALUE SUM(c[\\"Value\\"]) FROM c WHERE c.category = \'costs\'";\n            var queryDefinition = new QueryDefinition(sqlQueryText);\n            var queryResultSetIterator = container.GetItemQueryIterator<float>(queryDefinition);\n\n            float totalCost = 0;\n            if (queryResultSetIterator.HasMoreResults)\n            {\n                var response = await queryResultSetIterator.ReadNextAsync();\n                totalCost = response.FirstOrDefault();\n            }\n\n            return totalCost;\n        }\n\n        public async Task<string> GetCurrency(string client)\n        {\n            var container = _cosmosClient.GetContainer(databaseId, client);\n            var sqlQueryText = "SELECT TOP 1 c.Currency FROM c WHERE c.category = \'costs\'";\n            var queryDefinition = new QueryDefinition(sqlQueryText);\n            var queryResultSetIterator = container.GetItemQueryIterator<dynamic>(queryDefinition);\n\n            string currency = "EUR"; // Default to "EUR"\n            if (queryResultSetIterator.HasMoreResults)\n            {\n                var response = await queryResultSetIterator.ReadNextAsync();\n                var firstItem = response.FirstOrDefault();\n                if (firstItem != null)\n                {\n                    var currencyValue = firstItem?.Currency?.ToString();\n                    if (!string.IsNullOrEmpty(currencyValue))\n                    {\n                        currency = currencyValue;\n                    }\n                }\n            }\n\n            return currency;\n        }\n\n\n\n\n        public async Task<int> GetDefenderFree(string client)\n        {\n            var container = _cosmosClient.GetContainer(databaseId, client);\n            var sqlQueryText = "SELECT COUNT(1) as count FROM c WHERE c.category = \'defender\' AND c.Tier = \'Free\'";\n            var queryDefinition = new QueryDefinition(sqlQueryText);\n            var queryResultSetIterator = container.GetItemQueryIterator<dynamic>(queryDefinition);\n\n            int count = 0;\n            while (queryResultSetIterator.HasMoreResults)\n            {\n                var response = await queryResultSetIterator.ReadNextAsync();\n                count = response.FirstOrDefault().count;\n            }\n\n            return count;\n        }\n\n        public async Task<int> GetDefenderStandard(string client)\n        {\n            var container = _cosmosClient.GetContainer(databaseId, client);\n            var sqlQueryText = "SELECT COUNT(1) as count FROM c WHERE c.category = \'defender\' AND c.Tier = \'Standard\'";\n            var queryDefinition = new QueryDefinition(sqlQueryText);\n            var queryResultSetIterator = container.GetItemQueryIterator<dynamic>(queryDefinition);\n\n            int count = 0;\n            while (queryResultSetIterator.HasMoreResults)\n            {\n                var response = await queryResultSetIterator.ReadNextAsync();\n                count = response.FirstOrDefault().count;\n            }\n\n            return count;\n        }\n\n        public async Task<List<CostPerService>> GetCostByService(string client)\n        {\n            var container = _cosmosClient.GetContainer(databaseId, client);\n            var sqlQueryText = @"\n                SELECT c.ServiceName AS Name, SUM(c[""Value""]) AS Amount\n                FROM c\n                WHERE c.category = \'costs\'\n                GROUP BY c.ServiceName";\n            var queryDefinition = new QueryDefinition(sqlQueryText);\n            var queryResultSetIterator = container.GetItemQueryIterator<dynamic>(queryDefinition);\n\n            var results = new List<CostPerService>();\n            while (queryResultSetIterator.HasMoreResults)\n            {\n                var response = await queryResultSetIterator.ReadNextAsync();\n                results.AddRange(response.Select(item => new CostPerService\n                {\n                    Name = (string)item.Name,\n                    Amount = item.Amount\n                }));\n            }\n\n            return results;\n\n        }\n\n        public async Task<List<RecomendationByCategory>> GetRecomendationByCategory(string client)\n        {\n            var container = _cosmosClient.GetContainer(databaseId, client);\n            var sqlQueryText = @"\n                SELECT distinctServiceNames.Category AS Name, COUNT(1) AS Amount\n                FROM (\n                    SELECT DISTINCT c[""Service Name""], c[""Subscription""], c.Type, c[""Resource Group""], c.Category\n                    FROM c \n                    WHERE c.category = \'services\' \n                        AND c.Compliant = false\n                ) AS distinctServiceNames\n                GROUP BY distinctServiceNames.Category";\n\n            var queryDefinition = new QueryDefinition(sqlQueryText);\n            var queryResultSetIterator = container.GetItemQueryIterator<dynamic>(queryDefinition);\n\n            var results = new List<RecomendationByCategory>();\n            while (queryResultSetIterator.HasMoreResults)\n            {\n                var response = await queryResultSetIterator.ReadNextAsync();\n                results.AddRange(response.Select(item => new RecomendationByCategory\n                {\n                    Name = (string)item.Name,\n                    Amount = (int)item.Amount\n                }));\n            }\n\n            return results;\n        }\n\n        public async Task<int> GetNumberOfSubscriptions(string tenantId)\n        {\n            // Primero busca el Tenant correspondiente al tenantId de Azure\n            var tenant = await _context.Tenants.FirstOrDefaultAsync(t => t.TenantId == tenantId);\n\n            if (tenant == null)\n            {\n                // Si no se encuentra, retorna 0 o lanza una excepción si es necesario\n                return 0;\n            }\n\n            // Ahora usa el Id numérico del Tenant para contar las suscripciones\n            var numberOfSubscriptions = await _context.Subscriptions\n                .Where(s => s.TenantId == tenant.Id)\n                .CountAsync();\n\n            return numberOfSubscriptions;\n        }\n\n\n        public async Task<int> GetNumberOfResources(string client)\n        {\n            var stopwatch = Stopwatch.StartNew();\n            var container = _cosmosClient.GetContainer(databaseId, client);\n            var sqlQueryText = @"\n                    SELECT VALUE COUNT(1) FROM (\n                        SELECT DISTINCT c[""Resource Group""]\n                        FROM c\n                        WHERE c.category = \'services\' AND c[""Resource Group""] != \'\'\n                    )";\n            stopwatch.Stop();\n            _logger.LogInformation($"GetNumberOfResources executed in {stopwatch.ElapsedMilliseconds} ms");\n            return await ExecuteCountQueryNormal(container, sqlQueryText);\n        }\n\n\n        public async Task<List<ResourceType>> GetResourceTypes(string client)\n        {\n            var results = new List<ResourceType>();\n            try\n            {\n                var stopwatch = Stopwatch.StartNew();\n                var container = _cosmosClient.GetContainer(databaseId, client);\n                var sqlQueryText = @"\n                    SELECT ds.Type, COUNT(1) AS total\n                    FROM (\n                        SELECT DISTINCT c[""Service Name""], c[""Resource Group""], c.Type\n                        FROM c\n                        WHERE c.category = \'services\'\n                              AND IS_DEFINED(c[""Service Name""]) AND c[""Service Name""] != \'\'\n                              AND IS_DEFINED(c[""Resource Group""]) AND c[""Resource Group""] != \'\'\n                    ) AS ds\n                    GROUP BY ds.Type";\n                var queryDefinition = new QueryDefinition(sqlQueryText);\n                var queryResultSetIterator = container.GetItemQueryIterator<dynamic>(queryDefinition);\n\n                while (queryResultSetIterator.HasMoreResults)\n                {\n                    var response = await queryResultSetIterator.ReadNextAsync();\n                    var batchResults = response\n                        .Where(item => item != null && !string.IsNullOrEmpty((string)item.Type))\n                        .Select(item => new ResourceType\n                        {\n                            Name = (string)item.Type,\n                            Amount = (int)item.total\n                        })\n                        .ToList();\n\n                    results.AddRange(batchResults);\n                }\n\n                stopwatch.Stop();\n                _logger.LogInformation($"GetResourceTypes executed in {stopwatch.ElapsedMilliseconds} ms");\n\n                return results;\n            }\n            catch (Exception ex)\n            {\n                _logger.LogError(ex, "An error occurred while querying the resource types");\n                return results;\n            }\n        }\n\n        public class ResourceByRegionResult\n        {\n            public string Location { get; set; } = string.Empty;\n            public int count { get; set; }\n        }\n\n        public async Task<List<ResourceByRegion>> GetResourcesByRegion(string client)\n        {\n            var container = _cosmosClient.GetContainer(databaseId, client);\n            var sqlQueryText = @"\n        SELECT distinctGroups.Location, COUNT(1) AS count\n        FROM (\n            SELECT DISTINCT c[""Resource Group""], c.Location\n            FROM c\n            WHERE c.category = \'services\' AND c[""Resource Group""] != \'\'\n        ) AS distinctGroups\n        GROUP BY distinctGroups.Location";\n\n            var queryDefinition = new QueryDefinition(sqlQueryText);\n            var queryResultSetIterator = container.GetItemQueryIterator<ResourceByRegionResult>(queryDefinition);\n\n            var results = new List<ResourceByRegionResult>();\n\n            while (queryResultSetIterator.HasMoreResults)\n            {\n                var response = await queryResultSetIterator.ReadNextAsync();\n                results.AddRange(response);\n            }\n\n            var resourcesByCountry = results\n                .Where(item => item != null && !string.IsNullOrEmpty(item.Location))\n                .Select(item => new ResourceByRegion\n                {\n                    Name = item.Location,\n                    Amount = item.count\n                })\n                .ToList();\n\n            return resourcesByCountry;\n        }\n\n\n\n        public async Task<List<ResourceByCategory>> GetResourcesByCategory(string client)\n        {\n            try\n            {\n                var stopwatch = Stopwatch.StartNew();\n                var container = _cosmosClient.GetContainer(databaseId, client);\n                var sqlQueryText = @"\n                    SELECT c.category, COUNT(1) as count \n                    FROM c \n                    WHERE c.category NOT IN (\'advisor\', \'advisory\', \'costs\', \'defender\', \'overview\', \'services\', \'subscriptions\') \n                    GROUP BY c.category";\n                var queryDefinition = new QueryDefinition(sqlQueryText);\n                var queryResultSetIterator = container.GetItemQueryIterator<dynamic>(queryDefinition);\n\n                var results = new List<ResourceByCategory>();\n                while (queryResultSetIterator.HasMoreResults)\n                {\n                    var response = await queryResultSetIterator.ReadNextAsync();\n                    foreach (var item in response)\n                    {\n                        results.Add(new ResourceByCategory\n                        {\n                            Name = (string)item.category,\n                            Amount = (int)item.count\n                        });\n                    }\n                }\n                stopwatch.Stop();\n                _logger.LogInformation($"GetResourcesByCategory executed in {stopwatch.ElapsedMilliseconds} ms");\n\n                return results;\n            }\n            catch (Exception ex)\n            {\n                _logger.LogError(ex, "An error occurred while querying the resources by category");\n                return new List<ResourceByCategory>();\n            }\n        }\n\n\n        private async Task<int> ExecuteCountQuery(Container container, string sqlQueryText)\n        {\n            var queryDefinition = new QueryDefinition(sqlQueryText);\n            var queryResultSetIterator = container.GetItemQueryIterator<int>(queryDefinition);\n\n            var results = new List<int>();\n\n            while (queryResultSetIterator.HasMoreResults)\n            {\n                var response = await queryResultSetIterator.ReadNextAsync();\n                results.AddRange(response);\n            }\n\n            return results.FirstOrDefault();\n        }\n\n        public async Task<int> GetNumComplDisaster(string client)\n        {\n            var stopwatch = Stopwatch.StartNew();\n            var container = _cosmosClient.GetContainer(databaseId, client);\n            var sqlQueryText = @"\n                SELECT VALUE COUNT(1) \n                FROM (\n                    SELECT DISTINCT c[\'Service Name\'] , c[\'Subscription\'] , c[\'Type\'] , c[\'Resource Group\'] \n                    FROM c \n                    WHERE c.category = \'services\' \n                          AND c.Category = \'Disaster Recovery\'\n                          AND c.Compliant = true\n                          AND IS_DEFINED(c[\'Service Name\']) AND c[\'Service Name\'] != \'\'\n                ) AS distinctServiceNames";\n            stopwatch.Stop();\n            _logger.LogInformation($"GetNumComplDisaster executed in {stopwatch.ElapsedMilliseconds} ms");\n            return await ExecuteCountQuery(container, sqlQueryText);\n        }\n\n        public async Task<int> GetNumN